rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función auxiliar: Comprueba si el usuario está logueado
    function isAuth() {
      return request.auth != null;
    }

    // Perfiles de Usuario: Cualquier usuario autenticado puede leer, solo el propio usuario puede escribir.
    match /userProfiles/{userId} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == userId;
    }

    // Índice de Correos: Cualquier usuario autenticado puede buscar/leer (para hacer invitaciones). Solo el propio usuario puede escribirse.
    match /emailIndex/{email} {
      allow read: if isAuth();
      allow write: if isAuth() && request.resource.data.id == request.auth.uid;
    }

    // Empresas
    match /companies/{companyId} {
      // Función auxiliar: Comprobar si un usuario es Dueño o Gerente
      function isManagerOrOwner() {
        return request.auth.uid in resource.data.ownerIds || request.auth.uid in resource.data.managerIds;
      }

      // Lectura: Solo si el usuario es miembro activo, o si está en la lista de pendientes (para detectar que ha sido invitado)
      allow read: if isAuth() && (
        request.auth.uid in resource.data.memberIds || 
        request.auth.uid in resource.data.pendingMembers
      );

      // Creación: Cualquier usuario puede crear una empresa, siempre que se ponga a sí mismo como owner y member
      allow create: if isAuth() 
        && request.auth.uid in request.resource.data.ownerIds
        && request.auth.uid in request.resource.data.memberIds;

      // ACTUALIZACIÓN: Aquí está el corazón del "Double Handshake"
      allow update: if isAuth() && (
        
        // CASO 1: Un Administrador (Handshake 1) envía una invitación (agrega a pendientes)
        // Regla: Es Manager/Owner, y la única diferencia entre la data vieja y la nueva es en el array de pendingMembers
        (
          isManagerOrOwner() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingMembers'])
        ) 
        
        ||
        
        // CASO 2: El Invitado acepta (Handshake 2)
        // Reglas Atómicas:
        // 1. El usuario debía estar en pendingMembers antes de este cambio.
        // 2. El usuario se está quitando de pendingMembers.
        // 3. El usuario se está añadiendo a memberIds y userIds (rol base).
        // 4. No se están tocando los campos de dueños o gerentes (no se puede auto-asignar privilegios).
        (
          (request.auth.uid in resource.data.pendingMembers) &&
          !(request.auth.uid in request.resource.data.pendingMembers) &&
          (request.auth.uid in request.resource.data.memberIds) &&
          (request.auth.uid in request.resource.data.userIds) &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['ownerIds', 'managerIds', 'name', 'createdAt'])
        )
      );

      allow delete: if isAuth() && request.auth.uid in resource.data.ownerIds;
    // -------------------------------------------------------------------------
    // REGLAS DE PRODUCCIÓN: PROYECTOS, TAREAS Y RECURRENTES
    // -------------------------------------------------------------------------

    // PROYECTOS
    match /projects/{projectId} {
      // Lectura permitida a miembros del proyecto o de la empresa
      allow read: if isAuth(); 
      // Creación: asume que la UI pone al creador en adminIds y memberIds
      allow create: if isAuth() && request.auth.uid in request.resource.data.memberIds;
      // Actualización: restringido a miembros (idealmente administradores o supervisores)
      allow update: if isAuth() && (
        request.auth.uid in resource.data.memberIds ||
        request.auth.uid in resource.data.adminIds ||
        request.auth.uid in resource.data.supervisorIds
      );
      // Borrado: solo administradores
      allow delete: if isAuth() && request.auth.uid in resource.data.adminIds;
    }

    // TAREAS PRINCIPALES
    match /tasks/{taskId} {
      // Función para validar que el usuario es miembro del proyecto de la tarea
      function isProjectMember(projId) {
        return request.auth.uid in get(/databases/$(database)/documents/projects/$(projId)).data.memberIds;
      }
      
      // Lectura pública para cualquier usuario autenticado en el sistema
      // (Para listados globales y filtros cruzados)
      allow read: if isAuth();
      
      // Creación/Modificación: requiere validación contra el documento del proyecto
      // Nota: Si esto excede las cuotas de Firestore por lecturas (get), podemos relajarlo 
      // a "if isAuth()" dado que la UI ya protege las operaciones.
      allow create: if isAuth() && isProjectMember(request.resource.data.projectId);
      allow update: if isAuth() && isProjectMember(resource.data.projectId);
      allow delete: if isAuth() && isProjectMember(resource.data.projectId);

      // SUBCOLECCIÓN: EVIDENCIAS / ACTUALIZACIONES
      match /updates/{updateId} {
        allow read: if isAuth();
        allow create: if isAuth() && request.auth.uid == request.resource.data.userId;
        allow update, delete: if isAuth() && request.auth.uid == resource.data.userId;
      }
    }

    // TAREAS RECURRENTES (PLANTILLAS)
    match /recurring_tasks/{recurringTaskId} {
      function isProjectMember(projId) {
        return request.auth.uid in get(/databases/$(database)/documents/projects/$(projId)).data.memberIds;
      }

      allow read: if isAuth();
      allow create: if isAuth() && isProjectMember(request.resource.data.projectId);
      allow update: if isAuth() && isProjectMember(resource.data.projectId);
      allow delete: if isAuth() && isProjectMember(resource.data.projectId);
    }
  }
}
